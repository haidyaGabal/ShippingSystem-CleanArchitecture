@model List<CityDTO>
@{
    ViewBag.Title = "Cities";
}
@section Styles {
    <!-- Custom styles for this template -->
    <link href="css/sb-admin-2.min.css" rel="stylesheet">

    <!-- Custom styles for this page -->
    <link href="vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet">
}

<div class="container ">


    <!-- Table Card -->
    <div class="card shadow">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="card-title mb-0">@Labels.Cities</h6>
                <a asp-controller="City"
                   asp-action="Edit"
                   asp-route-countryId="@ViewBag.SelectedCountryId"
                   class="btn btn-success btn-sm mb-3">
                    <i class="bi bi-plus-lg"></i> Add New
                </a>

            </div>

            <div class="table-responsive">
                <table class="table table-bordered dataTable" id="dataTable" width="100%" cellspacing="0" role="grid" aria-describedby="dataTable_info" style="width: 100%;">
                    <thead>
                        <tr role="row">
                            <th class="sorting sorting_asc" tabindex="0" aria-controls="dataTable" rowspan="1" colspan="1" aria-sort="ascending" aria-label="Name: activate to sort column descending" style="width: 141.429px;">@Labels.NameEn</th>
                            <th class="sorting sorting_asc" tabindex="0" aria-controls="dataTable" rowspan="1" colspan="1" aria-sort="ascending" aria-label="Name: activate to sort column descending" style="width: 141.429px;">@Labels.NameAr</th>
                            <th class="sorting sorting_asc" tabindex="0" aria-controls="dataTable" rowspan="1" colspan="1" aria-sort="ascending" aria-label="Name: activate to sort column descending" style="width: 141.429px;">@Labels.NameEn</th>
                            <th class="sorting sorting_asc" tabindex="0" aria-controls="dataTable" rowspan="1" colspan="1" aria-sort="ascending" aria-label="Name: activate to sort column descending" style="width: 141.429px;">@Labels.NameAr</th>
              
                            <th class="sorting" tabindex="0" aria-controls="dataTable" rowspan="1" colspan="1" aria-label="Position: activate to sort column ascending" style="width: 219.429px;">@Labels.Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var country = ((List<CountryDTO>)ViewBag.lstCountry)
                            .FirstOrDefault(c => c.Id == item.CountryId);

                            <tr>
                                <td class="text-start">@item.CityEname</td>
                                <td class="text-start">@item.CityAname</td>

                                <td class="text-start">@country?.CountryEname</td>
                                <td class="text-start">@country?.CountryAname</td>

                                <td class="text-center">
                                    <a asp-controller="City"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm me-1">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>

                                    <form asp-area="admin"
                                          asp-controller="City"
                                          asp-action="Delete"
                                          method="post"
                                          style="display:inline"
                                          onsubmit="return confirm('Are you sure you want to delete this City?');">

                                        @Html.AntiForgeryToken()
                                       
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="countryId" value="@item.CountryId" />

                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>


                </table>
            </div>
        </div>
    </div>

</div>


@section Scripts {


    <!-- Page level plugins -->
    <script src="~/Admin/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>

    <!-- Page level custom scripts -->
    <script src="~/Admin/js/demo/datatables-demo.js"></script>

}
