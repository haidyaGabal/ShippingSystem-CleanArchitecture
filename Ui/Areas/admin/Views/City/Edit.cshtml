@model CityDTO


<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 fw-bold mb-1">Shipping Type</h1>
            <p class="text-muted mb-0">Create or update shipping methods</p>
        </div>
        <a asp-area="Admin"
           asp-controller="City"
           asp-action="Index"
           class="btn btn-outline-secondary">
            <i class="mdi mdi-arrow-left me-1"></i> Back
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-6 col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">

                <!-- Card Header -->
                <div class="card-header bg-white border-bottom rounded-top-4">
                    <h5 class="fw-semibold mb-0">Shipping Type Details</h5>
                    <small class="text-muted">All fields marked * are required</small>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">
                    <form asp-area="Admin"
                          asp-controller="City"
                          asp-action="Save"
                          method="post"
                          novalidate>

                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CountryId" />

                        <!-- Arabic Name -->
                        <div class="mb-3">
                            <label asp-for="CityAname" class="form-label fw-semibold">
                                @Labels.NameAr <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="mdi mdi-translate"></i>
                                </span>
                                <input asp-for="CityAname"
                                       class="form-control"
                                       placeholder="مثال: القاهرة" />
                            </div>
                            <span class="text-danger small" asp-validation-for="CityAname"></span>
                        </div>

                        <!-- English Name -->
                        <div class="mb-3">
                            <label asp-for="CityEname" class="form-label fw-semibold">
                               @Labels.NameEn <span class="text-danger">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="mdi mdi-alphabetical"></i>
                                </span>
                                <input asp-for="CityEname"
                                       class="form-control"
                                       placeholder="e.g. Cairo" />
                            </div>
                            <span class="text-danger small" asp-validation-for="CityEname"></span>
                        </div>

                

                        <hr class="my-4" />

                        <!-- Actions -->
                        <div class="d-flex justify-content-end gap-3">
                            <button type="reset" class="btn btn-light">
                                Reset
                            </button>
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="mdi mdi-content-save-outline me-1"></i>
                                Save
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<style>
.card {
    transition: box-shadow .2s ease;
}

.card:hover {
    box-shadow: 0 .75rem 2rem rgba(0,0,0,.08);
}

.form-control:focus {
    border-color: #4f46e5;
    box-shadow: 0 0 0 .2rem rgba(79,70,229,.15);
}

.input-group-text {
    background-color: #f8f9fa;
}
</style>